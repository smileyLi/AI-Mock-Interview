# ========== API配置 ==========
# DeepSeek API密钥（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DeepSeek API地址（默认即可，无需修改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 模型名称（默认即可，无需修改）
# LLM_MODEL=deepseek-chat

# ========== JWT配置 ==========
# JWT密钥（必填）- 用于用户认证
# 请使用随机字符串，建议至少32个字符
JWT_SECRET_KEY=your_jwt_secret_key_here_at_least_32_chars

# ========== 服务器配置 ==========
# 本地开发默认 127.0.0.1:8000，部署到云服务器时改为 0.0.0.0
HOST=127.0.0.1
PORT=8000
# 前端端口（仅本地 run.py 启动时使用）
# FRONTEND_PORT=8765

# ========== CORS配置 ==========
# 部署到云服务器时必须设置此项，多个域名用逗号分隔
# 例如：ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# 留空则使用本地开发默认值（127.0.0.1 / localhost）

# ========== SMTP邮件配置 ==========
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=...@qq.com
SMTP_PASSWORD=授权码

# ========== RAG知识库配置（可选）==========
# 是否启用RAG知识库检索
# RAG_ENABLED=false
# RAG数据库路径（默认 data/chroma_db）
# RAG_DB_DIR=data/chroma_db
# Embedding模型路径或HuggingFace模型名
# RAG_ST_MODEL_PATH=models/bge-small-zh-v1.5
