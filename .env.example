# ========== API配置 ==========
# DeepSeek API密钥（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DeepSeek API地址（默认即可，无需修改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 模型名称（默认即可，无需修改）
# LLM_MODEL=deepseek-chat

# ========== JWT配置 ==========
# JWT密钥（必填）- 用于用户认证
# 请使用随机字符串，建议至少32个字符
JWT_SECRET_KEY=your_jwt_secret_key_here_at_least_32_chars

# ========== 服务器配置 ==========
# 生产部署时建议使用 127.0.0.1（由 Nginx 反向代理），开发时默认 127.0.0.1
HOST=127.0.0.1
PORT=8000
# 前端端口（仅本地 run.py 开发模式使用，生产环境由 Nginx 提供）
# FRONTEND_PORT=8765

# ========== 部署模式 ==========
# 生产部署时设为 true，去掉热重载，不启动前端 http.server
# PRODUCTION=true

# ========== CORS配置 ==========
# 部署时设置你的域名（多个用逗号分隔），留空则使用本地开发默认值
# 如果使用 Nginx 反向代理（前后端同域），此项可不设置
# ALLOWED_ORIGINS=https://你的IP.nip.io

# ========== SMTP邮件配置 ==========
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=...@qq.com
SMTP_PASSWORD=授权码

# ========== 代理设置 ==========
# 部署环境需要走代理访问外网时设为 false，关闭强制禁用代理
# OPENAI_DISABLE_PROXY=true

# ========== 日志配置 ==========
# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO
# 启用文件日志（生产环境建议开启）
# LOG_FILE_ENABLED=true
# 日志目录
# LOG_DIR=logs

# ========== RAG知识库配置（可选）==========
# 是否启用RAG知识库检索
# RAG_ENABLED=false
# RAG数据库路径（默认 data/chroma_db）
# RAG_DB_DIR=data/chroma_db
# Embedding模型路径或HuggingFace模型名
# RAG_ST_MODEL_PATH=models/bge-small-zh-v1.5
